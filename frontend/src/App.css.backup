@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Space+Mono:wght@400;700&family=Outfit:wght@300;400;500;600;700;800;900&display=swap');

/* ==================== CSS VARIABLES ==================== */
:root {
  --bg-void: #050505;
  --bg-surface: #121214;
  --bg-elevated: #1A1A22;
  --bg-glass: rgba(18, 18, 20, 0.85);
  
  --text-primary: #FFFFFF;
  --text-secondary: #A1A1AA;
  --text-muted: #52525B;
  
  --accent-primary: #E0FF00;
  --accent-primary-hover: #D1ED00;
  --accent-win: #00FFA3;
  --accent-loss: #FF2346;
  --accent-osrs: #FFC800;
  --accent-crypto: #00E0FF;
  
  --border-subtle: rgba(255, 255, 255, 0.08);
  --border-focus: #E0FF00;
  
  --font-display: 'Orbitron', monospace;
  --font-body: 'Outfit', sans-serif;
  --font-mono: 'Space Mono', monospace;
  --font-brand: 'Orbitron', monospace;
  
  --sidebar-width: 240px;
  --sidebar-collapsed: 72px;
  --header-height: 64px;
  --chat-width: 320px;
  
  --transition-fast: 0.15s ease;
  --transition-normal: 0.3s ease;
  --transition-slow: 0.5s ease;
}

/* ==================== RESET & BASE ==================== */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html, body {
  height: 100%;
  overflow: hidden;
}

body {
  font-family: var(--font-body);
  background: var(--bg-void);
  color: var(--text-primary);
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

/* Noise texture overlay */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  opacity: 0.03;
  pointer-events: none;
  z-index: 9999;
}

a {
  color: inherit;
  text-decoration: none;
}

button {
  font-family: inherit;
  cursor: pointer;
  border: none;
  background: none;
  color: inherit;
}

input, select, textarea {
  font-family: inherit;
  background: var(--bg-void);
  border: 1px solid var(--border-subtle);
  color: var(--text-primary);
  padding: 12px 16px;
  border-radius: 8px;
  outline: none;
  transition: border-color var(--transition-fast);
}

input:focus, select:focus, textarea:focus {
  border-color: var(--accent-primary);
  box-shadow: 0 0 0 2px rgba(224, 255, 0, 0.1);
}

input[type="number"] {
  font-family: var(--font-mono);
}

/* ==================== APP LAYOUT ==================== */
.app {
  display: grid;
  grid-template-columns: var(--sidebar-width) 1fr var(--chat-width);
  grid-template-rows: 1fr;
  height: 100vh;
  overflow: hidden;
}

.app.sidebar-collapsed {
  grid-template-columns: var(--sidebar-collapsed) 1fr var(--chat-width);
}

.app:not(.chat-open) {
  grid-template-columns: var(--sidebar-width) 1fr 0;
}

.app.sidebar-collapsed:not(.chat-open) {
  grid-template-columns: var(--sidebar-collapsed) 1fr 0;
}

/* ==================== SIDEBAR ==================== */
.sidebar {
  background: var(--bg-surface);
  border-right: 1px solid var(--border-subtle);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: width var(--transition-normal);
}

.sidebar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  border-bottom: 1px solid var(--border-subtle);
  min-height: 64px;
}

.logo {
  display: flex;
  align-items: center;
  gap: 12px;
}

.logo-icon {
  width: 32px;
  height: 32px;
  color: var(--accent-primary);
  filter: drop-shadow(0 0 8px rgba(224, 255, 0, 0.5));
}

.logo-text {
  font-family: var(--font-display);
  font-size: 18px;
  letter-spacing: 2px;
  color: var(--text-primary);
}

.collapse-btn {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  color: var(--text-muted);
  transition: all var(--transition-fast);
}

.collapse-btn:hover {
  background: var(--bg-elevated);
  color: var(--text-primary);
}

.sidebar-nav {
  flex: 1;
  overflow-y: auto;
  padding: 16px 8px;
}

.nav-section {
  margin-bottom: 24px;
}

.nav-section-title {
  display: block;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 1px;
  color: var(--text-muted);
  padding: 8px 12px;
  margin-bottom: 4px;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  border-radius: 8px;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
  margin-bottom: 4px;
}

.nav-item:hover {
  background: var(--bg-elevated);
  color: var(--text-primary);
}

.nav-item.active {
  background: linear-gradient(135deg, rgba(224, 255, 0, 0.15), rgba(224, 255, 0, 0.05));
  color: var(--accent-primary);
  box-shadow: inset 0 0 0 1px rgba(224, 255, 0, 0.2);
}

.nav-icon {
  width: 20px;
  height: 20px;
  flex-shrink: 0;
}

.sidebar.collapsed .nav-item span,
.sidebar.collapsed .nav-section-title,
.sidebar.collapsed .logo-text {
  display: none;
}

/* ==================== MAIN CONTENT ==================== */
.main-content {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--bg-void);
}

/* ==================== HEADER ==================== */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 24px;
  background: var(--bg-surface);
  border-bottom: 1px solid var(--border-subtle);
  min-height: var(--header-height);
  backdrop-filter: blur(20px);
}

.header-left, .header-right {
  display: flex;
  align-items: center;
  gap: 16px;
}

.balance-display {
  display: flex;
  align-items: center;
  gap: 12px;
}

.currency-selector {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  background: var(--bg-elevated);
  border-radius: 8px;
  cursor: pointer;
  position: relative;
  transition: all var(--transition-fast);
}

.currency-selector:hover {
  background: var(--bg-void);
}

.currency-icon {
  font-size: 18px;
  font-weight: bold;
}

.balance-amount {
  font-family: var(--font-mono);
  font-weight: 600;
  font-size: 14px;
}

.dropdown-arrow {
  width: 16px;
  height: 16px;
  color: var(--text-muted);
}

.currency-dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  margin-top: 4px;
  background: var(--bg-elevated);
  border: 1px solid var(--border-subtle);
  border-radius: 8px;
  overflow: hidden;
  z-index: 100;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
}

.currency-option {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 12px;
  transition: all var(--transition-fast);
}

.currency-option:hover {
  background: var(--bg-void);
}

.currency-option.active {
  background: rgba(224, 255, 0, 0.1);
}

.currency-name {
  flex: 1;
  font-size: 12px;
}

.currency-balance {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text-muted);
}

.deposit-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  background: var(--accent-primary);
  color: #000;
  font-weight: 600;
  font-size: 13px;
  border-radius: 8px;
  transition: all var(--transition-fast);
}

.deposit-btn:hover {
  background: var(--accent-primary-hover);
  transform: translateY(-1px);
}

.chat-toggle-btn {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-elevated);
  border-radius: 8px;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
}

.chat-toggle-btn:hover {
  color: var(--accent-primary);
}

.user-menu {
  display: flex;
  align-items: center;
  gap: 12px;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 8px;
}

.user-avatar {
  width: 36px;
  height: 36px;
  background: linear-gradient(135deg, var(--accent-primary), var(--accent-win));
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  color: #000;
}

.user-name {
  font-weight: 500;
  font-size: 14px;
}

.logout-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  color: var(--text-muted);
  transition: all var(--transition-fast);
}

.logout-btn:hover {
  background: rgba(255, 35, 70, 0.1);
  color: var(--accent-loss);
}

.auth-buttons {
  display: flex;
  gap: 8px;
}

.login-btn, .register-btn {
  padding: 8px 20px;
  border-radius: 8px;
  font-weight: 500;
  font-size: 14px;
  transition: all var(--transition-fast);
}

.login-btn {
  color: var(--text-secondary);
}

.login-btn:hover {
  color: var(--text-primary);
}

.register-btn {
  background: var(--accent-primary);
  color: #000;
}

.register-btn:hover {
  background: var(--accent-primary-hover);
}

/* ==================== PAGE CONTENT ==================== */
.page-content {
  flex: 1;
  overflow-y: auto;
  padding: 24px;
}

/* ==================== CHAT PANEL ==================== */
.chat-panel {
  background: var(--bg-surface);
  border-left: 1px solid var(--border-subtle);
  display: flex;
  flex-direction: column;
  transition: width var(--transition-normal);
  overflow: hidden;
}

.chat-panel:not(.open) {
  width: 0;
  border: none;
}

.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  border-bottom: 1px solid var(--border-subtle);
  min-height: 56px;
}

.chat-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-weight: 600;
}

.connection-status {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--accent-loss);
}

.connection-status.online {
  background: var(--accent-win);
  box-shadow: 0 0 8px var(--accent-win);
}

.close-chat {
  color: var(--text-muted);
}

.chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.chat-message {
  padding: 8px 12px;
  background: var(--bg-elevated);
  border-radius: 8px;
  font-size: 13px;
}

.chat-message.rain {
  background: rgba(224, 255, 0, 0.1);
  border: 1px solid rgba(224, 255, 0, 0.3);
}

.chat-message.tip {
  background: rgba(0, 255, 163, 0.1);
  border: 1px solid rgba(0, 255, 163, 0.3);
}

.rain-alert, .tip-alert {
  display: flex;
  align-items: center;
  gap: 4px;
  font-weight: 600;
  margin-bottom: 4px;
}

.rain-alert {
  color: var(--accent-primary);
}

.tip-alert {
  color: var(--accent-win);
}

.message-user {
  font-weight: 600;
  color: var(--accent-crypto);
  margin-right: 6px;
}

.message-text {
  color: var(--text-secondary);
}

.chat-input-area {
  padding: 12px;
  border-top: 1px solid var(--border-subtle);
}

.chat-form {
  display: flex;
  gap: 8px;
}

.chat-form input {
  flex: 1;
  padding: 10px 14px;
  font-size: 13px;
}

.tip-btn, .send-btn {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-elevated);
  border-radius: 8px;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
}

.tip-btn:hover {
  color: var(--accent-osrs);
}

.send-btn:hover {
  background: var(--accent-primary);
  color: #000;
}

.tip-form {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.tip-form input {
  padding: 10px;
  font-size: 12px;
}

.send-tip-btn, .cancel-tip-btn {
  padding: 10px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 600;
}

.send-tip-btn {
  background: var(--accent-win);
  color: #000;
}

.cancel-tip-btn {
  background: var(--bg-elevated);
}

.chat-login-prompt {
  padding: 16px;
  text-align: center;
  color: var(--text-muted);
  font-size: 13px;
}

/* ==================== GAME PAGES ==================== */
.game-page {
  max-width: 1200px;
  margin: 0 auto;
}

.game-main {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 24px;
}

@media (max-width: 900px) {
  .game-main {
    grid-template-columns: 1fr;
  }
}

.game-canvas {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
  padding: 32px;
  min-height: 500px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.game-betting {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
  padding: 24px;
}

.game-controls {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.bet-input-group label {
  display: block;
  font-size: 12px;
  font-weight: 500;
  color: var(--text-muted);
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.bet-input-wrapper {
  display: flex;
  gap: 8px;
}

.bet-input-wrapper input {
  flex: 1;
  font-family: var(--font-mono);
  font-size: 16px;
  font-weight: 600;
}

.bet-modifiers {
  display: flex;
  gap: 4px;
}

.bet-modifiers button {
  padding: 8px 12px;
  background: var(--bg-elevated);
  border-radius: 6px;
  font-size: 12px;
  font-weight: 600;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
}

.bet-modifiers button:hover:not(:disabled) {
  background: var(--bg-void);
  color: var(--text-primary);
}

.bet-button {
  width: 100%;
  padding: 16px;
  background: var(--accent-win);
  color: #000;
  font-family: var(--font-display);
  font-size: 20px;
  letter-spacing: 2px;
  border-radius: 12px;
  transition: all var(--transition-fast);
  box-shadow: 0 0 20px rgba(0, 255, 163, 0.3);
}

.bet-button:hover:not(:disabled) {
  transform: scale(1.02);
  box-shadow: 0 0 30px rgba(0, 255, 163, 0.5);
}

.bet-button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* ==================== DICE GAME ==================== */
.dice-display {
  width: 100%;
  text-align: center;
}

.dice-result {
  font-family: var(--font-display);
  font-size: 80px;
  color: var(--text-primary);
  transition: all var(--transition-normal);
}

.dice-result.win {
  color: var(--accent-win);
  text-shadow: 0 0 40px var(--accent-win);
}

.dice-result.lose {
  color: var(--accent-loss);
  text-shadow: 0 0 40px var(--accent-loss);
}

.dice-slider-container {
  margin: 40px 0;
  padding: 0 20px;
}

.dice-slider {
  width: 100%;
  height: 12px;
  -webkit-appearance: none;
  background: linear-gradient(to right, var(--accent-loss) 0%, var(--accent-loss) var(--value, 50%), var(--accent-win) var(--value, 50%), var(--accent-win) 100%);
  border-radius: 6px;
  outline: none;
}

.dice-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 28px;
  height: 28px;
  background: var(--text-primary);
  border-radius: 50%;
  cursor: pointer;
  box-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
}

.slider-markers {
  display: flex;
  justify-content: space-between;
  margin-top: 12px;
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--text-muted);
  position: relative;
}

.target-marker {
  position: absolute;
  transform: translateX(-50%);
  color: var(--accent-primary);
  font-weight: 700;
}

.dice-direction {
  display: flex;
  gap: 12px;
  justify-content: center;
  margin-top: 24px;
}

.direction-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  background: var(--bg-elevated);
  border-radius: 8px;
  font-weight: 600;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
}

.direction-btn:hover {
  background: var(--bg-void);
}

.direction-btn.active {
  background: var(--accent-primary);
  color: #000;
}

.dice-stats {
  display: flex;
  gap: 24px;
  justify-content: center;
  margin-top: 32px;
}

.stat-box {
  text-align: center;
}

.stat-label {
  display: block;
  font-size: 11px;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 4px;
}

.stat-value {
  font-family: var(--font-mono);
  font-size: 20px;
  font-weight: 700;
  color: var(--accent-primary);
}

.stat-value.win {
  color: var(--accent-win);
}

/* Auto Bet */
.auto-bet-section {
  margin-top: 24px;
  padding-top: 24px;
  border-top: 1px solid var(--border-subtle);
}

.auto-bet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.auto-bet-header span {
  font-weight: 600;
  font-size: 14px;
}

.auto-bet-toggle {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-elevated);
  border-radius: 8px;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
}

.auto-bet-toggle.active {
  background: var(--accent-loss);
  color: #fff;
}

.auto-bet-count {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--accent-primary);
  margin-bottom: 12px;
}

.auto-bet-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.auto-bet-input label {
  display: block;
  font-size: 10px;
  color: var(--text-muted);
  margin-bottom: 4px;
}

.auto-bet-input input {
  width: 100%;
  padding: 8px;
  font-size: 12px;
}

/* ==================== KENO GAME ==================== */
.keno-board {
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  gap: 8px;
  width: 100%;
  max-width: 500px;
}

.keno-cell {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-elevated);
  border: 2px solid transparent;
  border-radius: 8px;
  font-family: var(--font-mono);
  font-weight: 700;
  font-size: 14px;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
  cursor: pointer;
}

.keno-cell:hover:not(:disabled) {
  background: var(--bg-void);
  border-color: var(--border-subtle);
}

.keno-cell.selected {
  background: var(--accent-primary);
  color: #000;
  border-color: var(--accent-primary);
}

.keno-cell.drawn {
  background: var(--bg-void);
  border-color: var(--accent-crypto);
  color: var(--accent-crypto);
}

.keno-cell.hit {
  background: var(--accent-win);
  border-color: var(--accent-win);
  color: #000;
  box-shadow: 0 0 20px rgba(0, 255, 163, 0.5);
}

.keno-info {
  width: 100%;
  margin-top: 24px;
}

.keno-stats {
  display: flex;
  gap: 16px;
  justify-content: center;
  margin-bottom: 16px;
}

.keno-actions {
  display: flex;
  gap: 12px;
  justify-content: center;
}

.quick-pick-btn, .clear-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  background: var(--bg-elevated);
  border-radius: 8px;
  font-weight: 500;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
}

.quick-pick-btn:hover {
  background: var(--accent-primary);
  color: #000;
}

.clear-btn:hover {
  background: var(--accent-loss);
  color: #fff;
}

.keno-paytable {
  margin-top: 24px;
  padding-top: 24px;
  border-top: 1px solid var(--border-subtle);
}

.keno-paytable h4 {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 12px;
}

.paytable-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}

.paytable-row {
  display: flex;
  justify-content: space-between;
  padding: 6px 10px;
  background: var(--bg-elevated);
  border-radius: 6px;
  font-size: 11px;
}

.paytable-row span:last-child {
  font-family: var(--font-mono);
  color: var(--accent-primary);
}

/* ==================== CRASH GAME ==================== */
.crash-canvas {
  position: relative;
  overflow: hidden;
}

.crash-display {
  text-align: center;
  transition: all var(--transition-normal);
}

.crash-display.crashed {
  animation: screenShake 0.5s ease-out;
}

@keyframes screenShake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-10px); }
  40% { transform: translateX(10px); }
  60% { transform: translateX(-5px); }
  80% { transform: translateX(5px); }
}

.crash-rocket {
  position: relative;
  display: inline-block;
  margin-bottom: 24px;
}

.rocket-icon {
  width: 80px;
  height: 80px;
  color: var(--accent-primary);
  transition: all var(--transition-normal);
}

.rocket-icon.flying {
  animation: rocketShake 0.1s infinite;
  color: var(--accent-win);
  filter: drop-shadow(0 0 20px var(--accent-win));
}

@keyframes rocketShake {
  0%, 100% { transform: translate(0, 0) rotate(-10deg); }
  25% { transform: translate(-2px, 2px) rotate(-8deg); }
  50% { transform: translate(2px, -2px) rotate(-12deg); }
  75% { transform: translate(-1px, 1px) rotate(-10deg); }
}

.rocket-flames {
  position: absolute;
  bottom: -30px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 2px;
}

.rocket-flames svg {
  width: 24px;
  height: 24px;
  color: var(--accent-loss);
  animation: flameFlicker 0.2s infinite;
}

@keyframes flameFlicker {
  0%, 100% { opacity: 1; transform: scaleY(1); }
  50% { opacity: 0.7; transform: scaleY(0.8); }
}

.crash-multiplier {
  font-family: var(--font-display);
  font-size: 100px;
  color: var(--accent-win);
  text-shadow: 0 0 40px var(--accent-win);
  transition: all var(--transition-fast);
}

.crash-multiplier.crashed {
  color: var(--accent-loss);
  text-shadow: 0 0 40px var(--accent-loss);
}

.crash-multiplier.cashed {
  color: var(--accent-primary);
  text-shadow: 0 0 40px var(--accent-primary);
}

.crash-explosion {
  font-family: var(--font-display);
  font-size: 32px;
  color: var(--accent-loss);
  margin-top: 16px;
  animation: pulseText 0.5s ease-out;
}

.cash-out-indicator {
  font-family: var(--font-display);
  font-size: 24px;
  color: var(--accent-primary);
  margin-top: 16px;
}

@keyframes pulseText {
  0% { transform: scale(1.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.crash-history {
  display: flex;
  gap: 8px;
  justify-content: center;
  margin-top: 24px;
  flex-wrap: wrap;
}

.crash-history-item {
  padding: 6px 12px;
  background: var(--bg-elevated);
  border-radius: 6px;
  font-family: var(--font-mono);
  font-size: 12px;
  font-weight: 600;
}

.crash-history-item.high {
  color: var(--accent-win);
  background: rgba(0, 255, 163, 0.1);
}

.crash-history-item.low {
  color: var(--accent-loss);
  background: rgba(255, 35, 70, 0.1);
}

.cash-out-input {
  margin-bottom: 16px;
}

.cash-out-input label {
  display: block;
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 8px;
}

.cash-out-input input {
  width: 100%;
  font-family: var(--font-mono);
  font-size: 18px;
  font-weight: 700;
  text-align: center;
}

.potential-win {
  display: flex;
  justify-content: space-between;
  padding: 12px;
  background: var(--bg-elevated);
  border-radius: 8px;
  margin-top: 16px;
  font-size: 14px;
}

.win-amount {
  font-family: var(--font-mono);
  font-weight: 700;
  color: var(--accent-win);
}

/* ==================== WHEEL GAME ==================== */
.wheel-canvas {
  position: relative;
}

.wheel-container {
  position: relative;
  width: 400px;
  height: 400px;
}

.wheel-pointer {
  position: absolute;
  top: -20px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  color: var(--accent-primary);
  filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.5));
}

.wheel {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  position: relative;
  border: 4px solid var(--border-subtle);
  box-shadow: 0 0 40px rgba(224, 255, 0, 0.2);
}

.wheel-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80px;
  height: 80px;
  background: var(--bg-void);
  border-radius: 50%;
  border: 3px solid var(--accent-primary);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 5;
}

.goat-icon, .money-icon {
  width: 24px;
  height: 24px;
  color: var(--accent-primary);
}

.wheel-segment {
  position: absolute;
  width: 50%;
  height: 50%;
  top: 0;
  left: 50%;
  transform-origin: 0% 100%;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 20px;
  clip-path: polygon(0% 100%, 100% 0%, 100% 100%);
}

.segment-value {
  font-family: var(--font-display);
  font-size: 14px;
  color: #000;
  transform: rotate(9deg);
}

.wheel-result {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  font-family: var(--font-display);
  font-size: 48px;
  padding: 16px 32px;
  background: var(--bg-surface);
  border-radius: 12px;
  border: 2px solid var(--accent-primary);
}

.wheel-result.win {
  color: var(--accent-win);
  border-color: var(--accent-win);
}

.wheel-result.lose {
  color: var(--accent-loss);
  border-color: var(--accent-loss);
}

.wheel-legend {
  margin-top: 24px;
  padding-top: 24px;
  border-top: 1px solid var(--border-subtle);
}

.wheel-legend h4 {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 12px;
}

.legend-items {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

.legend-item {
  font-family: var(--font-mono);
  font-weight: 700;
  font-size: 14px;
}

/* ==================== PLINKO GAME ==================== */
.plinko-canvas {
  position: relative;
}

.plinko-board {
  width: 100%;
  max-width: 500px;
  position: relative;
  padding: 20px;
}

.plinko-row {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-bottom: 16px;
}

.plinko-peg {
  width: 10px;
  height: 10px;
  background: var(--text-muted);
  border-radius: 50%;
}

.plinko-ball {
  position: absolute;
  width: 20px;
  height: 20px;
  background: var(--accent-primary);
  border-radius: 50%;
  box-shadow: 0 0 15px var(--accent-primary);
  transition: all 0.1s ease;
}

.plinko-buckets {
  display: flex;
  gap: 4px;
  justify-content: center;
  margin-top: 20px;
}

.plinko-bucket {
  padding: 8px 4px;
  border-radius: 4px;
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 700;
  color: #000;
  min-width: 28px;
  text-align: center;
  transition: all var(--transition-fast);
}

.plinko-bucket.active {
  transform: scale(1.2);
  box-shadow: 0 0 20px currentColor;
}

/* ==================== LIMBO GAME ==================== */
.limbo-canvas {
  text-align: center;
}

.limbo-display {
  padding: 40px;
}

.limbo-result {
  font-family: var(--font-display);
  font-size: 120px;
  color: var(--text-primary);
  transition: all var(--transition-normal);
}

.limbo-display.win .limbo-result {
  color: var(--accent-win);
  text-shadow: 0 0 60px var(--accent-win);
}

.limbo-display.lose .limbo-result {
  color: var(--accent-loss);
  text-shadow: 0 0 60px var(--accent-loss);
}

.limbo-target {
  font-family: var(--font-mono);
  font-size: 20px;
  color: var(--text-muted);
  margin-top: 16px;
}

.limbo-history {
  display: flex;
  gap: 8px;
  justify-content: center;
  margin-top: 32px;
  flex-wrap: wrap;
}

.limbo-history-item {
  padding: 6px 12px;
  background: var(--bg-elevated);
  border-radius: 6px;
  font-family: var(--font-mono);
  font-size: 12px;
  font-weight: 600;
}

.limbo-history-item.win {
  color: var(--accent-win);
}

.limbo-history-item.lose {
  color: var(--accent-loss);
}

.target-input {
  margin-bottom: 16px;
}

.target-input label {
  display: block;
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 8px;
}

.target-input input {
  width: 100%;
  font-family: var(--font-mono);
  font-size: 24px;
  font-weight: 700;
  text-align: center;
}

.target-quick-picks {
  display: flex;
  gap: 8px;
  margin-top: 12px;
}

.target-quick-picks button {
  flex: 1;
  padding: 8px;
  background: var(--bg-elevated);
  border-radius: 6px;
  font-family: var(--font-mono);
  font-size: 12px;
  font-weight: 600;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
}

.target-quick-picks button:hover:not(:disabled) {
  background: var(--accent-primary);
  color: #000;
}

.limbo-stats {
  display: flex;
  gap: 16px;
  margin-bottom: 16px;
}

.limbo-stats .stat-box {
  flex: 1;
  padding: 12px;
  background: var(--bg-elevated);
  border-radius: 8px;
}

/* ==================== GAME HISTORY ==================== */
.game-history {
  margin-top: 24px;
  padding: 24px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
}

.game-history h3 {
  font-size: 14px;
  color: var(--text-muted);
  margin-bottom: 16px;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  max-height: 200px;
  overflow-y: auto;
}

.history-item {
  display: flex;
  justify-content: space-between;
  padding: 10px 14px;
  background: var(--bg-elevated);
  border-radius: 8px;
}

.history-roll {
  font-family: var(--font-mono);
  font-weight: 600;
}

.history-result {
  font-family: var(--font-mono);
  font-weight: 700;
}

.history-result.win {
  color: var(--accent-win);
}

.history-result.lose {
  color: var(--accent-loss);
}

/* ==================== AUTH PAGES ==================== */
.auth-page {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: calc(100vh - var(--header-height) - 48px);
}

.auth-card {
  width: 100%;
  max-width: 400px;
  padding: 40px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
}

.auth-header {
  text-align: center;
  margin-bottom: 32px;
}

.auth-logo {
  width: 48px;
  height: 48px;
  color: var(--accent-primary);
  margin-bottom: 16px;
}

.auth-header h1 {
  font-family: var(--font-display);
  font-size: 28px;
  margin-bottom: 8px;
}

.auth-header p {
  color: var(--text-muted);
  font-size: 14px;
}

.input-group {
  margin-bottom: 20px;
}

.input-group label {
  display: block;
  font-size: 12px;
  font-weight: 500;
  color: var(--text-muted);
  margin-bottom: 8px;
}

.input-group input {
  width: 100%;
}

.auth-submit {
  width: 100%;
  padding: 14px;
  background: var(--accent-primary);
  color: #000;
  font-weight: 700;
  font-size: 14px;
  border-radius: 8px;
  transition: all var(--transition-fast);
}

.auth-submit:hover:not(:disabled) {
  background: var(--accent-primary-hover);
  transform: translateY(-1px);
}

.auth-submit:disabled {
  opacity: 0.5;
}

.auth-switch {
  text-align: center;
  margin-top: 24px;
  font-size: 14px;
  color: var(--text-muted);
}

.auth-switch a {
  color: var(--accent-primary);
  font-weight: 500;
}

/* ==================== WALLET PAGE ==================== */
.wallet-page h1 {
  font-family: var(--font-display);
  font-size: 32px;
  margin-bottom: 32px;
}

.wallet-balances {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
  gap: 12px;
  margin-bottom: 32px;
}

.balance-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  cursor: pointer;
  transition: all var(--transition-fast);
}

.balance-card:hover {
  border-color: var(--text-muted);
}

.balance-card.active {
  border-color: var(--accent-primary);
  background: rgba(224, 255, 0, 0.05);
}

.balance-card .balance-icon {
  font-size: 24px;
  margin-bottom: 8px;
}

.balance-card .balance-name {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 4px;
}

.balance-card .balance-amount {
  font-family: var(--font-mono);
  font-weight: 700;
}

.wallet-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 24px;
}

.wallet-tabs button {
  padding: 12px 24px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 8px;
  font-weight: 500;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
}

.wallet-tabs button:hover {
  border-color: var(--text-muted);
}

.wallet-tabs button.active {
  background: var(--accent-primary);
  border-color: var(--accent-primary);
  color: #000;
}

.wallet-content {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
  padding: 24px;
}

.deposit-address {
  margin-bottom: 24px;
}

.deposit-address label {
  display: block;
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 8px;
}

.address-box {
  display: flex;
  gap: 8px;
  padding: 12px;
  background: var(--bg-void);
  border-radius: 8px;
}

.address-box code {
  flex: 1;
  font-family: var(--font-mono);
  font-size: 12px;
  word-break: break-all;
}

.address-box button {
  color: var(--text-muted);
  transition: all var(--transition-fast);
}

.address-box button:hover {
  color: var(--accent-primary);
}

.deposit-note {
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 8px;
}

.demo-deposit {
  padding: 20px;
  background: var(--bg-elevated);
  border-radius: 12px;
}

.demo-deposit h4 {
  font-size: 14px;
  margin-bottom: 12px;
  color: var(--accent-primary);
}

.demo-deposit input {
  width: 100%;
  margin-bottom: 12px;
}

.demo-deposit button {
  width: 100%;
  padding: 12px;
  background: var(--accent-win);
  color: #000;
  font-weight: 600;
  border-radius: 8px;
}

.withdraw-section .available {
  display: block;
  font-size: 11px;
  color: var(--text-muted);
  margin-top: 4px;
}

.withdraw-btn {
  width: 100%;
  padding: 14px;
  background: var(--accent-primary);
  color: #000;
  font-weight: 700;
  border-radius: 8px;
  margin-top: 16px;
}

.withdraw-btn:disabled {
  opacity: 0.5;
}

.transaction-history {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.transaction-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px;
  background: var(--bg-elevated);
  border-radius: 8px;
}

.tx-type {
  font-weight: 600;
  text-transform: capitalize;
}

.tx-currency {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text-muted);
  margin-left: 8px;
}

.tx-amount {
  font-family: var(--font-mono);
  font-weight: 700;
}

.transaction-item.deposit .tx-amount {
  color: var(--accent-win);
}

.transaction-item.withdrawal .tx-amount {
  color: var(--accent-loss);
}

.tx-status {
  font-size: 11px;
  text-transform: uppercase;
  padding: 4px 8px;
  background: var(--bg-void);
  border-radius: 4px;
}

.no-transactions {
  text-align: center;
  color: var(--text-muted);
  padding: 40px;
}

/* ==================== VIP PAGE ==================== */
.vip-page h1 {
  font-family: var(--font-display);
  font-size: 32px;
  margin-bottom: 32px;
}

.vip-status-card {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 40px;
  padding: 32px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
  margin-bottom: 32px;
}

.vip-tier {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.vip-tier svg {
  width: 48px;
  height: 48px;
  margin-bottom: 12px;
}

.vip-tier h2 {
  font-family: var(--font-display);
  font-size: 28px;
}

.vip-level {
  font-size: 12px;
  color: var(--text-muted);
}

.vip-progress-section {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8px;
  font-size: 14px;
}

.progress-bar {
  height: 12px;
  background: var(--bg-void);
  border-radius: 6px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent-primary), var(--accent-win));
  border-radius: 6px;
  transition: width var(--transition-slow);
}

.progress-stats {
  display: flex;
  justify-content: space-between;
  margin-top: 8px;
  font-size: 12px;
  color: var(--text-muted);
}

.vip-rewards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  margin-bottom: 32px;
}

.reward-card {
  padding: 24px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  text-align: center;
}

.reward-card h3 {
  font-size: 14px;
  color: var(--text-muted);
  margin-bottom: 8px;
}

.reward-rate {
  font-family: var(--font-display);
  font-size: 48px;
  color: var(--accent-primary);
  margin-bottom: 16px;
}

.reward-available {
  display: flex;
  justify-content: space-between;
  padding: 12px;
  background: var(--bg-elevated);
  border-radius: 8px;
  margin-bottom: 16px;
  font-size: 14px;
}

.reward-available .amount {
  font-family: var(--font-mono);
  font-weight: 700;
  color: var(--accent-win);
}

.reward-card button {
  width: 100%;
  padding: 12px;
  background: var(--accent-primary);
  color: #000;
  font-weight: 600;
  border-radius: 8px;
  transition: all var(--transition-fast);
}

.reward-card button:disabled {
  opacity: 0.5;
}

.unlock-note {
  font-size: 11px;
  color: var(--text-muted);
  margin-top: 8px;
}

.vip-tiers-section h2 {
  font-size: 20px;
  margin-bottom: 20px;
}

.tiers-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12px;
}

.tier-card {
  padding: 20px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  text-align: center;
  transition: all var(--transition-fast);
}

.tier-card.current {
  border-color: var(--accent-primary);
  background: rgba(224, 255, 0, 0.05);
}

.tier-card.achieved {
  opacity: 0.6;
}

.tier-card svg {
  width: 32px;
  height: 32px;
  margin-bottom: 8px;
}

.tier-card h4 {
  font-size: 14px;
  margin-bottom: 4px;
}

.tier-wager {
  font-size: 11px;
  color: var(--text-muted);
  margin-bottom: 12px;
}

.tier-benefits {
  list-style: none;
  font-size: 11px;
  color: var(--text-secondary);
}

.tier-benefits li {
  margin-bottom: 4px;
}

/* ==================== PROVABLY FAIR PAGE ==================== */
.provably-fair-page h1 {
  font-family: var(--font-display);
  font-size: 32px;
  margin-bottom: 16px;
}

.fair-intro {
  color: var(--text-secondary);
  margin-bottom: 32px;
  max-width: 600px;
}

.current-seeds {
  padding: 24px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
  margin-bottom: 32px;
}

.current-seeds h2 {
  font-size: 18px;
  margin-bottom: 20px;
}

.seed-box {
  margin-bottom: 16px;
}

.seed-box label {
  display: block;
  font-size: 11px;
  color: var(--text-muted);
  margin-bottom: 4px;
}

.seed-box code {
  display: block;
  padding: 12px;
  background: var(--bg-void);
  border-radius: 8px;
  font-family: var(--font-mono);
  font-size: 12px;
  word-break: break-all;
  color: var(--text-secondary);
}

.seed-box.revealed code {
  color: var(--accent-win);
}

.seed-box button {
  margin-top: 8px;
  color: var(--text-muted);
  font-size: 12px;
  display: flex;
  align-items: center;
  gap: 4px;
}

.hash-display {
  font-size: 10px !important;
}

.rotate-seed-section {
  margin-top: 24px;
  padding-top: 24px;
  border-top: 1px solid var(--border-subtle);
}

.rotate-seed-section h3 {
  font-size: 14px;
  margin-bottom: 8px;
}

.rotate-seed-section p {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 12px;
}

.rotate-input {
  display: flex;
  gap: 8px;
}

.rotate-input input {
  flex: 1;
}

.rotate-input button {
  padding: 12px 20px;
  background: var(--accent-primary);
  color: #000;
  font-weight: 600;
  border-radius: 8px;
}

.rotate-input button:disabled {
  opacity: 0.5;
}

.verify-section {
  padding: 24px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
  margin-bottom: 32px;
}

.verify-section h2 {
  font-size: 18px;
  margin-bottom: 20px;
}

.verify-form {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.verify-btn {
  grid-column: span 2;
  padding: 14px;
  background: var(--accent-primary);
  color: #000;
  font-weight: 700;
  border-radius: 8px;
}

.verify-result {
  margin-top: 20px;
  padding: 16px;
  background: var(--bg-void);
  border-radius: 8px;
}

.verify-result h3 {
  font-size: 14px;
  margin-bottom: 12px;
}

.verify-result pre {
  font-family: var(--font-mono);
  font-size: 11px;
  white-space: pre-wrap;
  word-break: break-all;
}

.how-it-works {
  padding: 24px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
}

.how-it-works h2 {
  font-size: 18px;
  margin-bottom: 20px;
}

.how-it-works ol {
  padding-left: 20px;
}

.how-it-works li {
  margin-bottom: 12px;
  color: var(--text-secondary);
  font-size: 14px;
}

.how-it-works strong {
  color: var(--accent-primary);
}

/* ==================== LEADERBOARD PAGE ==================== */
.leaderboard-page h1 {
  font-family: var(--font-display);
  font-size: 32px;
  margin-bottom: 32px;
}

.leaderboard-table {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
  overflow: hidden;
}

.leaderboard-header, .leaderboard-row {
  display: grid;
  grid-template-columns: 80px 1fr 100px 150px;
  padding: 16px 24px;
}

.leaderboard-header {
  background: var(--bg-elevated);
  font-size: 12px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.leaderboard-row {
  border-bottom: 1px solid var(--border-subtle);
  transition: all var(--transition-fast);
}

.leaderboard-row:hover {
  background: var(--bg-elevated);
}

.leaderboard-row:last-child {
  border-bottom: none;
}

.leaderboard-row.top-1 {
  background: rgba(255, 215, 0, 0.1);
}

.leaderboard-row.top-2 {
  background: rgba(192, 192, 192, 0.05);
}

.leaderboard-row.top-3 {
  background: rgba(205, 127, 50, 0.05);
}

.rank {
  font-family: var(--font-mono);
  font-weight: 700;
  display: flex;
  align-items: center;
}

.rank svg.gold {
  color: #FFD700;
}

.rank svg.silver {
  color: #C0C0C0;
}

.rank svg.bronze {
  color: #CD7F32;
}

.player {
  font-weight: 600;
}

.vip {
  font-size: 12px;
  font-weight: 600;
}

.wagered {
  font-family: var(--font-mono);
  font-weight: 700;
  color: var(--accent-primary);
}

/* ==================== HOME PAGE ==================== */
.home-page {
  max-width: 1200px;
  margin: 0 auto;
}

.hero-section {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 40px;
  align-items: center;
  padding: 60px 0;
  margin-bottom: 60px;
}

.hero-content h1 {
  font-family: var(--font-display);
  font-size: 72px;
  line-height: 1;
  margin-bottom: 16px;
  background: linear-gradient(135deg, var(--accent-primary), var(--accent-win));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.hero-tagline {
  font-size: 20px;
  color: var(--text-secondary);
  margin-bottom: 24px;
}

.hero-features {
  display: flex;
  gap: 24px;
  margin-bottom: 32px;
}

.hero-features span {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  color: var(--text-muted);
}

.hero-features svg {
  color: var(--accent-primary);
}

.hero-cta {
  display: flex;
  gap: 12px;
}

.cta-primary, .cta-secondary {
  padding: 14px 32px;
  font-weight: 700;
  border-radius: 8px;
  transition: all var(--transition-fast);
}

.cta-primary {
  background: var(--accent-primary);
  color: #000;
}

.cta-primary:hover {
  background: var(--accent-primary-hover);
  transform: translateY(-2px);
}

.cta-secondary {
  background: var(--bg-elevated);
  border: 1px solid var(--border-subtle);
}

.cta-secondary:hover {
  border-color: var(--accent-primary);
}

.hero-visual {
  position: relative;
}

.hero-diamond {
  width: 200px;
  height: 200px;
  color: var(--accent-primary);
  filter: drop-shadow(0 0 60px rgba(224, 255, 0, 0.5));
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20px); }
}

.games-section {
  margin-bottom: 60px;
}

.games-section h2 {
  font-family: var(--font-display);
  font-size: 28px;
  margin-bottom: 24px;
}

.games-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.game-card {
  padding: 32px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
  cursor: pointer;
  transition: all var(--transition-fast);
}

.game-card:hover {
  border-color: var(--accent-primary);
  transform: translateY(-4px);
  box-shadow: 0 8px 32px rgba(224, 255, 0, 0.1);
}

.game-icon {
  margin-bottom: 16px;
}

.game-card h3 {
  font-size: 18px;
  margin-bottom: 8px;
}

.game-card p {
  font-size: 14px;
  color: var(--text-muted);
}

.live-bets-section {
  margin-bottom: 60px;
}

.live-bets-section h2 {
  font-family: var(--font-display);
  font-size: 28px;
  margin-bottom: 24px;
}

.live-bets-table {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
  overflow: hidden;
}

.table-header, .table-row {
  display: grid;
  grid-template-columns: 1fr 100px 100px 100px 120px;
  padding: 12px 20px;
}

.table-header {
  background: var(--bg-elevated);
  font-size: 11px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
}

.table-row {
  border-bottom: 1px solid var(--border-subtle);
  font-size: 13px;
}

.table-row:last-child {
  border-bottom: none;
}

.table-row .player {
  font-weight: 500;
}

.table-row .game {
  text-transform: capitalize;
  color: var(--text-muted);
}

.table-row .bet, .table-row .multiplier {
  font-family: var(--font-mono);
}

.table-row .payout {
  font-family: var(--font-mono);
  font-weight: 700;
}

.table-row .payout.win {
  color: var(--accent-win);
}

.table-row .payout.lose {
  color: var(--accent-loss);
}

.features-section {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-bottom: 60px;
}

.feature {
  padding: 32px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
  text-align: center;
}

.feature svg {
  color: var(--accent-primary);
  margin-bottom: 16px;
}

.feature h3 {
  font-size: 16px;
  margin-bottom: 8px;
}

.feature p {
  font-size: 13px;
  color: var(--text-muted);
}

/* ==================== ADMIN PAGE ==================== */
.admin-page h1 {
  font-family: var(--font-display);
  font-size: 32px;
  margin-bottom: 24px;
}

.admin-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 24px;
}

.admin-tabs button {
  padding: 10px 20px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 8px;
  font-weight: 500;
}

.admin-tabs button.active {
  background: var(--accent-primary);
  border-color: var(--accent-primary);
  color: #000;
}

.admin-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

.stat-card {
  padding: 24px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  text-align: center;
}

.stat-card svg {
  color: var(--accent-primary);
  margin-bottom: 12px;
}

.stat-card .stat-value {
  font-family: var(--font-display);
  font-size: 32px;
  color: var(--text-primary);
}

.stat-card .stat-label {
  font-size: 12px;
  color: var(--text-muted);
}

.admin-users, .admin-bets {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.user-row, .bet-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  background: var(--bg-surface);
  border-radius: 8px;
}

.bet-row.win {
  border-left: 3px solid var(--accent-win);
}

.bet-row.lose {
  border-left: 3px solid var(--accent-loss);
}

/* ==================== LOADING ==================== */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60px;
  color: var(--text-muted);
}

/* ==================== RESPONSIVE ==================== */
@media (max-width: 1024px) {
  .app {
    grid-template-columns: 1fr;
  }
  
  .app.sidebar-collapsed {
    grid-template-columns: 1fr;
  }
  
  .sidebar {
    position: fixed;
    left: -100%;
    top: 0;
    bottom: 0;
    z-index: 1000;
    width: var(--sidebar-width);
    transition: left var(--transition-normal);
  }
  
  .sidebar.open {
    left: 0;
  }
  
  .chat-panel {
    position: fixed;
    right: -100%;
    top: 0;
    bottom: 0;
    z-index: 1000;
    width: var(--chat-width);
    transition: right var(--transition-normal);
  }
  
  .chat-panel.open {
    right: 0;
  }
  
  .hero-section {
    grid-template-columns: 1fr;
    text-align: center;
  }
  
  .hero-content h1 {
    font-size: 48px;
  }
  
  .hero-features {
    justify-content: center;
  }
  
  .hero-cta {
    justify-content: center;
  }
  
  .hero-visual {
    display: none;
  }
  
  .games-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .features-section {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .vip-rewards {
    grid-template-columns: 1fr;
  }
  
  .tiers-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 600px) {
  .games-grid {
    grid-template-columns: 1fr;
  }
  
  .features-section {
    grid-template-columns: 1fr;
  }
  
  .tiers-grid {
    grid-template-columns: 1fr;
  }
  
  .admin-stats {
    grid-template-columns: repeat(2, 1fr);
  }
}


/* ==================== OSRS GP DEPOSIT ==================== */
.osrs-deposit-section {
  padding: 24px;
}

.osrs-deposit-header {
  text-align: center;
  margin-bottom: 32px;
}

.osrs-deposit-header .osrs-icon {
  color: var(--accent-osrs);
  margin-bottom: 16px;
}

.osrs-deposit-header h2 {
  font-family: var(--font-display);
  font-size: 28px;
  margin-bottom: 8px;
}

.osrs-deposit-header p {
  color: var(--text-muted);
}

.osrs-deposit-form {
  max-width: 500px;
  margin: 0 auto;
}

.osrs-amount-selector {
  margin-bottom: 24px;
}

.osrs-amount-selector label {
  display: block;
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 12px;
}

.amount-slider-container {
  margin-bottom: 16px;
}

.osrs-slider {
  width: 100%;
  height: 12px;
  -webkit-appearance: none;
  background: linear-gradient(to right, var(--accent-osrs) 0%, var(--accent-win) 100%);
  border-radius: 6px;
  outline: none;
}

.osrs-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 28px;
  height: 28px;
  background: var(--text-primary);
  border-radius: 50%;
  cursor: pointer;
  box-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
}

.amount-display {
  text-align: center;
  margin-top: 12px;
}

.amount-value {
  font-family: var(--font-display);
  font-size: 48px;
  color: var(--accent-osrs);
}

.amount-presets {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.amount-presets button {
  flex: 1;
  min-width: 60px;
  padding: 10px;
  background: var(--bg-elevated);
  border-radius: 8px;
  font-weight: 600;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
}

.amount-presets button:hover,
.amount-presets button.active {
  background: var(--accent-osrs);
  color: #000;
}

.deposit-summary {
  background: var(--bg-elevated);
  border-radius: 12px;
  padding: 16px;
  margin: 24px 0;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  padding: 8px 0;
}

.summary-row:not(:last-child) {
  border-bottom: 1px solid var(--border-subtle);
}

.gp-amount {
  font-family: var(--font-mono);
  font-weight: 700;
  color: var(--accent-osrs);
}

.rsn {
  font-family: var(--font-mono);
  color: var(--accent-primary);
}

.osrs-deposit-btn {
  width: 100%;
  padding: 16px;
  background: var(--accent-osrs);
  color: #000;
  font-family: var(--font-display);
  font-size: 18px;
  letter-spacing: 1px;
  border-radius: 12px;
  transition: all var(--transition-fast);
}

.osrs-deposit-btn:hover:not(:disabled) {
  transform: scale(1.02);
  box-shadow: 0 0 30px rgba(255, 200, 0, 0.4);
}

.osrs-deposit-btn:disabled {
  opacity: 0.5;
}

.osrs-note {
  text-align: center;
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 16px;
}

/* Pending deposit */
.osrs-pending-deposit {
  text-align: center;
  padding: 32px;
  background: var(--bg-elevated);
  border-radius: 16px;
  max-width: 500px;
  margin: 0 auto;
}

.pending-badge {
  display: inline-block;
  padding: 6px 16px;
  background: var(--accent-osrs);
  color: #000;
  font-weight: 700;
  font-size: 12px;
  border-radius: 20px;
  margin-bottom: 16px;
}

.deposit-instructions {
  text-align: left;
  margin: 24px 0;
}

.instruction-step {
  display: flex;
  gap: 16px;
  margin-bottom: 16px;
  align-items: flex-start;
}

.instruction-step .step-num {
  width: 32px;
  height: 32px;
  background: var(--accent-primary);
  color: #000;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  flex-shrink: 0;
}

.rsn-display, .code-display {
  display: inline-block;
  padding: 8px 16px;
  background: var(--bg-void);
  border-radius: 8px;
  font-family: var(--font-mono);
  font-size: 16px;
  margin-left: 8px;
}

.rsn-display {
  color: var(--accent-primary);
}

.code-display {
  color: var(--accent-osrs);
}

.expire-note {
  font-size: 12px;
  color: var(--accent-loss);
  margin-top: 16px;
}

.new-deposit-btn {
  margin-top: 24px;
  padding: 12px 24px;
  background: var(--bg-void);
  border: 1px solid var(--border-subtle);
  border-radius: 8px;
  color: var(--text-secondary);
}

.osrs-redirect {
  text-align: center;
  padding: 40px;
}

.osrs-redirect button {
  margin-top: 16px;
  padding: 12px 24px;
  background: var(--accent-osrs);
  color: #000;
  font-weight: 600;
  border-radius: 8px;
}

/* Wallet limits info */
.wallet-limits-info {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 24px;
  padding: 16px;
  background: var(--bg-surface);
  border-radius: 12px;
  border: 1px solid var(--border-subtle);
}

.limit-item {
  display: flex;
  gap: 8px;
  font-size: 12px;
}

.limit-item span:first-child {
  color: var(--text-muted);
}

.limit-item span:last-child {
  color: var(--accent-primary);
  font-family: var(--font-mono);
}

.withdraw-limits {
  padding: 12px;
  background: var(--bg-elevated);
  border-radius: 8px;
  margin-bottom: 16px;
  font-size: 12px;
  color: var(--text-muted);
}

/* ==================== REFERRAL PAGE ==================== */
.referral-page {
  max-width: 900px;
  margin: 0 auto;
}

.referral-page h1 {
  font-family: var(--font-display);
  font-size: 32px;
  margin-bottom: 32px;
}

.referral-hero {
  text-align: center;
  padding: 48px;
  background: linear-gradient(135deg, rgba(0, 255, 163, 0.1), rgba(224, 255, 0, 0.1));
  border-radius: 20px;
  margin-bottom: 32px;
}

.referral-hero .referral-icon {
  color: var(--accent-win);
  margin-bottom: 16px;
}

.referral-hero h2 {
  font-family: var(--font-display);
  font-size: 36px;
  margin-bottom: 8px;
}

.referral-hero p {
  color: var(--text-secondary);
  font-size: 16px;
}

.referral-code-section {
  padding: 24px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
  margin-bottom: 24px;
}

.referral-code-section h3 {
  font-size: 16px;
  margin-bottom: 16px;
}

.code-box {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}

.referral-code {
  flex: 1;
  padding: 16px 24px;
  background: var(--bg-void);
  border-radius: 12px;
  font-family: var(--font-mono);
  font-size: 24px;
  font-weight: 700;
  color: var(--accent-primary);
  letter-spacing: 2px;
}

.code-box button {
  padding: 16px;
  background: var(--bg-elevated);
  border-radius: 12px;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
}

.code-box button:hover {
  color: var(--accent-primary);
}

.referral-link {
  display: flex;
  align-items: center;
  gap: 8px;
}

.referral-link span {
  font-size: 12px;
  color: var(--text-muted);
}

.referral-link input {
  flex: 1;
  padding: 10px;
  font-size: 12px;
  background: var(--bg-elevated);
}

.referral-link button {
  padding: 10px;
  color: var(--text-muted);
}

.referral-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-bottom: 24px;
}

.referral-stats .stat-card {
  padding: 24px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  text-align: center;
}

.referral-stats .stat-card svg {
  color: var(--accent-primary);
  margin-bottom: 12px;
}

.referral-stats .stat-value {
  display: block;
  font-family: var(--font-display);
  font-size: 32px;
  margin-bottom: 4px;
}

.referral-stats .stat-label {
  font-size: 12px;
  color: var(--text-muted);
}

.bonus-progress-section {
  padding: 24px;
  background: var(--bg-surface);
  border: 1px solid var(--accent-win);
  border-radius: 16px;
  margin-bottom: 24px;
}

.bonus-progress-section h3 {
  font-size: 16px;
  margin-bottom: 16px;
  color: var(--accent-win);
}

.bonus-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12px;
  font-size: 14px;
}

.progress-note {
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 12px;
  text-align: center;
}

.referred-users-section {
  padding: 24px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
  margin-bottom: 24px;
}

.referred-users-section h3 {
  font-size: 16px;
  margin-bottom: 16px;
}

.referred-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.referred-user {
  display: flex;
  justify-content: space-between;
  padding: 12px;
  background: var(--bg-elevated);
  border-radius: 8px;
}

.ref-username {
  font-weight: 600;
}

.ref-wagered {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--text-muted);
}

.redeem-section {
  padding: 24px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
  margin-bottom: 24px;
}

.redeem-section h3 {
  font-size: 16px;
  margin-bottom: 8px;
}

.redeem-section > p {
  color: var(--text-muted);
  font-size: 14px;
  margin-bottom: 16px;
}

.redeem-input {
  display: flex;
  gap: 12px;
}

.redeem-input input {
  flex: 1;
  font-family: var(--font-mono);
  font-size: 18px;
  text-transform: uppercase;
  letter-spacing: 2px;
}

.redeem-input button {
  padding: 14px 32px;
  background: var(--accent-win);
  color: #000;
  font-weight: 700;
  border-radius: 8px;
  transition: all var(--transition-fast);
}

.redeem-input button:hover:not(:disabled) {
  transform: translateY(-2px);
}

.redeem-input button:disabled {
  opacity: 0.5;
}

.redeem-note {
  font-size: 11px;
  color: var(--text-muted);
  margin-top: 12px;
}

.referral-page .how-it-works {
  margin-bottom: 24px;
}

.referral-page .how-it-works h3 {
  font-size: 18px;
  margin-bottom: 24px;
}

.steps {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

.step {
  text-align: center;
  padding: 24px 16px;
  background: var(--bg-elevated);
  border-radius: 12px;
}

.step .step-num {
  width: 40px;
  height: 40px;
  background: var(--accent-primary);
  color: #000;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-size: 20px;
  margin: 0 auto 12px;
}

.step h4 {
  font-size: 14px;
  margin-bottom: 8px;
}

.step p {
  font-size: 12px;
  color: var(--text-muted);
}

@media (max-width: 768px) {
  .referral-stats {
    grid-template-columns: 1fr;
  }
  
  .steps {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .redeem-input {
    flex-direction: column;
  }
}


/* ==================== KODAKGP PAGE ==================== */
.kodakgp-page {
  padding: 2rem;
  max-width: 1400px;
  margin: 0 auto;
}

.kodakgp-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2rem;
  padding: 2rem;
  background: linear-gradient(135deg, #1A1A22 0%, #050505 100%);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 1rem;
}

.kodakgp-header .header-content {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.kodakgp-icon {
  color: #FFC800;
  filter: drop-shadow(0 0 10px rgba(255, 200, 0, 0.5));
}

.kodakgp-header h1 {
  font-size: 2rem;
  margin: 0;
  background: linear-gradient(135deg, #FFC800, #E0FF00);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.rates-display {
  display: flex;
  gap: 1rem;
}

.rate-box {
  display: flex;
  flex-direction: column;
  padding: 1rem 2rem;
  background: #050505;
  border: 1px solid #FFC800;
  border-radius: 0.5rem;
}

.rate-label {
  font-size: 0.875rem;
  color: #A1A1AA;
  margin-bottom: 0.5rem;
}

.rate-value {
  font-size: 1.5rem;
  font-weight: bold;
  color: #FFC800;
}

.kodakgp-tabs {
  display: flex;
  gap: 1rem;
  margin-bottom: 2rem;
  border-bottom: 2px solid rgba(255, 255, 255, 0.1);
}

.kodakgp-tabs button {
  padding: 1rem 2rem;
  background: none;
  border: none;
  color: #A1A1AA;
  cursor: pointer;
  font-size: 1rem;
  font-weight: 600;
  border-bottom: 3px solid transparent;
  transition: all 0.3s;
}

.kodakgp-tabs button.active {
  color: #E0FF00;
  border-bottom-color: #E0FF00;
}

.kodakgp-tabs button:hover {
  color: #ffffff;
}

.kodakgp-content {
  background: #121214;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 1rem;
  padding: 2rem;
}

.section-desc {
  color: #A1A1AA;
  margin-bottom: 2rem;
}

.amount-selector {
  margin-bottom: 2rem;
}

.amount-selector input[type="range"] {
  width: 100%;
  height: 8px;
  background: linear-gradient(90deg, #FFC800, #E0FF00);
  border-radius: 4px;
  outline: none;
  margin: 1rem 0;
}

.amount-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem;
  background: #050505;
  border: 2px solid #E0FF00;
  border-radius: 0.75rem;
  margin: 1rem 0;
}

.amount-value {
  font-size: 2rem;
  font-weight: bold;
  color: #E0FF00;
}

.amount-usd {
  font-size: 1.5rem;
  color: #00FFA3;
}

.amount-presets {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.amount-presets button {
  padding: 0.75rem 1.5rem;
  background: #1A1A22;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 0.5rem;
  color: #ffffff;
  cursor: pointer;
  transition: all 0.2s;
}

.amount-presets button.active,
.amount-presets button:hover {
  background: #E0FF00;
  color: #000000;
  border-color: #E0FF00;
}

.info-box {
  background: rgba(224, 255, 0, 0.05);
  border: 1px solid rgba(224, 255, 0, 0.2);
  border-radius: 0.75rem;
  padding: 1.5rem;
  margin: 2rem 0;
}

.info-box h4 {
  color: #E0FF00;
  margin-bottom: 1rem;
}

.info-box ol {
  color: #A1A1AA;
  padding-left: 1.5rem;
}

.info-box ol li {
  margin: 0.5rem 0;
}

.order-btn,
.request-btn {
  width: 100%;
  padding: 1.5rem;
  background: linear-gradient(135deg, #FFC800, #E0FF00);
  color: #000000;
  border: none;
  border-radius: 0.75rem;
  font-size: 1.25rem;
  font-weight: bold;
  cursor: pointer;
  transition: all 0.3s;
  text-transform: uppercase;
  letter-spacing: 1px;
  box-shadow: 0 0 20px rgba(224, 255, 0, 0.3);
}

.order-btn:hover,
.request-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 0 30px rgba(224, 255, 0, 0.5);
}

.order-btn:disabled,
.request-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}

.services-list {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1rem;
  margin-bottom: 2rem;
}

.service-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem;
  background: #1A1A22;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 0.5rem;
  color: #ffffff;
}

.service-item svg {
  color: #00FFA3;
}

.service-request-form {
  background: #1A1A22;
  padding: 2rem;
  border-radius: 0.75rem;
}

.orders-list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.order-item {
  padding: 1.5rem;
  background: #1A1A22;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 0.75rem;
}

.order-item.pending {
  border-color: #FFC800;
}

.order-item.completed {
  border-color: #00FFA3;
}

.order-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 1rem;
}

.order-type {
  font-weight: bold;
  color: #E0FF00;
}

.order-status {
  padding: 0.25rem 0.75rem;
  border-radius: 0.25rem;
  font-size: 0.875rem;
  font-weight: 600;
  text-transform: uppercase;
}

.order-status.pending {
  background: rgba(255, 200, 0, 0.2);
  color: #FFC800;
}

.order-status.completed {
  background: rgba(0, 255, 163, 0.2);
  color: #00FFA3;
}

.order-details {
  display: flex;
  gap: 2rem;
  color: #A1A1AA;
}

.no-orders {
  text-align: center;
  color: #A1A1AA;
  padding: 3rem;
}

.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  text-align: center;
}

.login-prompt svg {
  color: #FFC800;
  margin-bottom: 2rem;
}

.login-prompt h2 {
  font-size: 2rem;
  margin-bottom: 1rem;
}

.login-prompt p {
  color: #A1A1AA;
  margin-bottom: 2rem;
}

.login-prompt .login-btn {
  padding: 1rem 3rem;
  background: #E0FF00;
  color: #000000;
  text-decoration: none;
  border-radius: 0.5rem;
  font-weight: bold;
  transition: all 0.3s;
}

.login-prompt .login-btn:hover {
  box-shadow: 0 0 20px rgba(224, 255, 0, 0.5);
}

