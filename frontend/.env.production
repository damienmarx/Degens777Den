# Production Environment Configuration
# Cloudflared Tunnel Setup

# Primary API endpoint (Cloudflared tunnel)
REACT_APP_BACKEND_URL=https://kodakclout-prod.workers.dev

# Fallback endpoints (for redundancy)
REACT_APP_BACKEND_FALLBACK=https://api.degens777den.com
REACT_APP_BACKEND_LOCAL=http://localhost:8001

# WebSocket configuration (for live chat, real-time updates)
REACT_APP_WS_URL=wss://kodakclout-prod.workers.dev/ws

# Discord webhook (for notifications)
REACT_APP_DISCORD_ENABLED=true

# Environment
REACT_APP_ENV=production
REACT_APP_VERSION=1.0.0

# Feature flags
REACT_APP_ENABLE_PWA=true
REACT_APP_ENABLE_OFFLINE=true
REACT_APP_ENABLE_ANALYTICS=true

# Performance
REACT_APP_API_TIMEOUT=30000
REACT_APP_CACHE_ENABLED=true
REACT_APP_CACHE_TTL=300000
